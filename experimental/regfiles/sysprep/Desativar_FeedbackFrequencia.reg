Windows Registry Editor Version 5.00

; Desativa prompts de feedback do Windows (Feedback Hub).
; NumberOfSIUFInPeriod = 0 equivale a configuracao "Nunca" no painel de controle.

[hkey_users\default\Software\Microsoft\Siuf\Rules]
"NumberOfSIUFInPeriod"=dword:00000000
"PeriodInNanoSeconds"=dword:00000000
